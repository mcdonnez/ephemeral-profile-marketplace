{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cookbookmcp.local/schemas/marketplace-cookbook.json",
  "title": "Cookbook MCP shareable cookbook (marketplace artifact)",
  "type": "object",
  "additionalProperties": true,
  "required": ["format", "version", "tools"],
  "properties": {
    "format": {
      "description": "Current exports use cookbookmcp-cookbook; cookbookmcp-profile is accepted for imports.",
      "enum": ["cookbookmcp-cookbook", "cookbookmcp-profile"]
    },
    "version": { "type": "integer", "minimum": 2 },
    "exportedAt": { "type": "string" },
    "documentOriginHint": { "type": ["string", "null"] },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["name", "enabled", "method", "urlTemplate", "inputSchema"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "aliases": { "type": "array", "items": { "type": "string" } },
          "enabled": { "type": "boolean" },
          "method": { "type": "string", "minLength": 1 },
          "urlTemplate": { "type": "string", "minLength": 1 },
          "inputSchema": { "type": ["object", "array", "string", "number", "boolean", "null"] },
          "fieldSemantics": { "type": "object" },
          "routeGroup": { "type": "object" }
        }
      }
    },
    "toolPlaybook": { "type": "object" },
    "routeGroups": { "type": "object" }
  }
}
